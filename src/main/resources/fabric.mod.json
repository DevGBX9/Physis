  },
  "license": "MIT",

  "icon": "icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "org.gbxteam.physis.Physis"
    ]
  },
  "mixins": [
    "physis.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.11.4",
