  "id": "${id}",
  "version": "${version}",

  "name": "${name}",
  "description": "A Minecraft mod dedicated to the dynamic growth and expansion of forests.",
  "authors": [
    "GBX Team"
  ],
  "contact": {
    "homepage": "https://modrinth.com/project/physis",
    "sources": "https://github.com/DevGBX9/Physis",
